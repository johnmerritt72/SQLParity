<UserControl x:Class="SQLParity.Vsix.Views.ConfirmationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <DockPanel Margin="12">
        <!-- Buttons at bottom -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Back"
                    Command="{Binding BackCommand}"
                    Padding="24,6" Margin="0,0,8,0" FontSize="14" />
            <Button Content="Begin Comparison"
                    Command="{Binding BeginComparisonCommand}"
                    Padding="24,6" FontSize="14" FontWeight="Bold" />
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="Confirm Comparison"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,16" />

        <!-- Two side panels -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Side A -->
            <Border Grid.Column="0" BorderThickness="2" CornerRadius="4"
                    BorderBrush="{Binding ColorA}" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding LabelA}" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding TagA}" FontStyle="Italic"
                               Foreground="{Binding ColorA}" Margin="0,0,0,12" />
                    <TextBlock Text="Server" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ServerA}" Margin="0,0,0,8" />
                    <TextBlock Text="Database" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DatabaseA}" />
                </StackPanel>
            </Border>

            <!-- Arrow -->
            <TextBlock Grid.Column="1" Text="&#x2194;"
                       FontSize="24" HorizontalAlignment="Center"
                       VerticalAlignment="Center" />

            <!-- Side B -->
            <Border Grid.Column="2" BorderThickness="2" CornerRadius="4"
                    BorderBrush="{Binding ColorB}" Padding="12">
                <StackPanel>
                    <TextBlock Text="{Binding LabelB}" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8" />
                    <TextBlock Text="{Binding TagB}" FontStyle="Italic"
                               Foreground="{Binding ColorB}" Margin="0,0,0,12" />
                    <TextBlock Text="Server" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding ServerB}" Margin="0,0,0,8" />
                    <TextBlock Text="Database" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DatabaseB}" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
