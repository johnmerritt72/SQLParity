<UserControl x:Class="SQLParity.Vsix.Views.ConnectionSetupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <DockPanel Margin="12">
        <!-- Duplicate label warning -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding DuplicateLabelWarning}"
                   Foreground="Red" FontWeight="SemiBold"
                   HorizontalAlignment="Right"
                   Margin="0,4,0,0"
                   Visibility="{Binding HasDuplicateLabels, Converter={StaticResource BoolToVis}}" />

        <!-- Object Type Filters (centered below both panels) -->
        <GroupBox DockPanel.Dock="Bottom" Header="Compare Object Types"
                  Margin="0,12,0,0" Padding="8"
                  HorizontalAlignment="Center">
            <StackPanel>
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <CheckBox Content="Tables" IsChecked="{Binding ObjectTypeFilter.IncludeTables}" Margin="8,2" />
                    <CheckBox Content="Views" IsChecked="{Binding ObjectTypeFilter.IncludeViews}" Margin="8,2" />
                    <CheckBox Content="Stored Procedures" IsChecked="{Binding ObjectTypeFilter.IncludeStoredProcedures}" Margin="8,2" />
                    <CheckBox Content="Functions" IsChecked="{Binding ObjectTypeFilter.IncludeFunctions}" Margin="8,2" />
                    <CheckBox Content="Schemas" IsChecked="{Binding ObjectTypeFilter.IncludeSchemas}" Margin="8,2" />
                    <CheckBox Content="Sequences" IsChecked="{Binding ObjectTypeFilter.IncludeSequences}" Margin="8,2" />
                    <CheckBox Content="Synonyms" IsChecked="{Binding ObjectTypeFilter.IncludeSynonyms}" Margin="8,2" />
                    <CheckBox Content="User-Defined Types" IsChecked="{Binding ObjectTypeFilter.IncludeUserDefinedDataTypes}" Margin="8,2" />
                    <CheckBox Content="User-Defined Table Types" IsChecked="{Binding ObjectTypeFilter.IncludeUserDefinedTableTypes}" Margin="8,2" />
                </WrapPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6,0,0">
                    <Button Content="Select All" Command="{Binding ObjectTypeFilter.SelectAllCommand}" Padding="8,2" Margin="4,0" />
                    <Button Content="Clear All" Command="{Binding ObjectTypeFilter.ClearAllCommand}" Padding="8,2" Margin="4,0" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Continue button at bottom -->
        <Button DockPanel.Dock="Bottom"
                Content="Continue"
                Command="{Binding ContinueCommand}"
                HorizontalAlignment="Right"
                Padding="24,6"
                Margin="0,12,0,0"
                FontSize="14" />

        <!-- Two-panel layout -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Side A -->
            <GroupBox Grid.Column="0" Header="Side A">
                <StackPanel Margin="8">
                    <TextBlock Text="Label" FontWeight="Bold" FontSize="14" />
                    <TextBox Text="{Binding SideA.Label, UpdateSourceTrigger=PropertyChanged}"
                             FontWeight="Bold" FontSize="14" Margin="0,2,0,8" />

                    <TextBlock Text="Tag (auto-suggested)" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding SideA.Tag}" FontStyle="Italic" Margin="0,0,0,8" />

                    <TextBlock Text="Server" Margin="0,0,0,2" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Connect"
                                Command="{Binding SideA.ConnectCommand}"
                                Padding="8,4" Margin="4,0,0,0" />
                        <ComboBox IsEditable="True"
                                  Text="{Binding SideA.ServerName, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding SideA.AvailableServers}"
                                  DisplayMemberPath="DisplayText"
                                  TextSearch.TextPath="ServerName" />
                    </DockPanel>

                    <!-- Connecting indicator -->
                    <TextBlock Text="Connecting..." Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideA.IsConnecting}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Connection error -->
                    <TextBlock Text="{Binding SideA.ConnectionError}" Foreground="Red"
                               TextWrapping="Wrap" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideA.ConnectionError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Database" Margin="0,0,0,2" />
                    <ComboBox IsEditable="True"
                              Text="{Binding SideA.DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding SideA.AvailableDatabases}"
                              Margin="0,0,0,4" />

                    <!-- Cache indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SideA.CacheStatus}" FontStyle="Italic" Foreground="Gray" Margin="0,0,8,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SideA.CacheStatus}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <CheckBox Content="Force refresh" IsChecked="{Binding SideA.ForceRefresh}"
                                  IsEnabled="{Binding SideA.HasCachedSchema}" VerticalAlignment="Center" />
                    </StackPanel>

                    <CheckBox Content="Use Windows Authentication"
                              IsChecked="{Binding SideA.UseWindowsAuth}"
                              Margin="0,0,0,8" />

                    <StackPanel x:Name="SqlAuthA">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideA.UseWindowsAuth}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Login" Margin="0,0,0,2" />
                        <TextBox Text="{Binding SideA.SqlLogin, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" />
                        <TextBlock Text="Password" Margin="0,0,0,2" />
                        <PasswordBox x:Name="PasswordA" Margin="0,0,0,8" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Side B -->
            <GroupBox Grid.Column="2" Header="Side B">
                <StackPanel Margin="8">
                    <TextBlock Text="Label" FontWeight="Bold" FontSize="14" />
                    <TextBox Text="{Binding SideB.Label, UpdateSourceTrigger=PropertyChanged}"
                             FontWeight="Bold" FontSize="14" Margin="0,2,0,8" />

                    <TextBlock Text="Tag (auto-suggested)" Margin="0,0,0,2" />
                    <TextBlock Text="{Binding SideB.Tag}" FontStyle="Italic" Margin="0,0,0,8" />

                    <!-- Mode selector: live database vs SSMS solution folder. -->
                    <TextBlock Text="Source" FontWeight="SemiBold" Margin="0,0,0,2" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton GroupName="SideBMode" Content="Database"
                                     IsChecked="{Binding SideB.IsDatabaseMode}"
                                     Margin="0,0,12,0" />
                        <RadioButton GroupName="SideBMode" Content="Folder (SSMS Solution)"
                                     IsChecked="{Binding SideB.IsFolderMode}"
                                     IsEnabled="{Binding IsSolutionOpen}"
                                     ToolTip="Open a SSMS Solution to enable folder mode." />
                    </StackPanel>

                    <!-- Folder-mode panel: displays the active solution directory.
                         Hidden when SideB.IsDatabaseMode == true. -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideB.IsFolderMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Solution Folder" Margin="0,0,0,2" />
                        <TextBox Text="{Binding SideB.FolderPath, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="#F5F5F5"
                                 Margin="0,0,0,4" />
                        <TextBlock Foreground="Gray" FontStyle="Italic"
                                   TextWrapping="Wrap" Margin="0,0,0,8"
                                   Text="Reading *.sql files at the root of this folder. Subfolders are ignored in v1.2." />
                    </StackPanel>

                    <!-- Database-mode panel: existing controls. Hidden when folder mode is on. -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideB.IsFolderMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                    <TextBlock Text="Server" Margin="0,0,0,2" />
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Connect"
                                Command="{Binding SideB.ConnectCommand}"
                                Padding="8,4" Margin="4,0,0,0" />
                        <ComboBox IsEditable="True"
                                  Text="{Binding SideB.ServerName, UpdateSourceTrigger=PropertyChanged}"
                                  ItemsSource="{Binding SideB.AvailableServers}"
                                  DisplayMemberPath="DisplayText"
                                  TextSearch.TextPath="ServerName" />
                    </DockPanel>

                    <!-- Connecting indicator -->
                    <TextBlock Text="Connecting..." Foreground="Gray" FontStyle="Italic" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideB.IsConnecting}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Connection error -->
                    <TextBlock Text="{Binding SideB.ConnectionError}" Foreground="Red"
                               TextWrapping="Wrap" Margin="0,0,0,4">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideB.ConnectionError}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Database" Margin="0,0,0,2" />
                    <ComboBox IsEditable="True"
                              Text="{Binding SideB.DatabaseName, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding SideB.AvailableDatabases}"
                              Margin="0,0,0,4" />

                    <!-- Cache indicator -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SideB.CacheStatus}" FontStyle="Italic" Foreground="Gray" Margin="0,0,8,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SideB.CacheStatus}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <CheckBox Content="Force refresh" IsChecked="{Binding SideB.ForceRefresh}"
                                  IsEnabled="{Binding SideB.HasCachedSchema}" VerticalAlignment="Center" />
                    </StackPanel>

                    <CheckBox Content="Use Windows Authentication"
                              IsChecked="{Binding SideB.UseWindowsAuth}"
                              Margin="0,0,0,8" />

                    <StackPanel x:Name="SqlAuthB">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SideB.UseWindowsAuth}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Login" Margin="0,0,0,2" />
                        <TextBox Text="{Binding SideB.SqlLogin, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,8" />
                        <TextBlock Text="Password" Margin="0,0,0,2" />
                        <PasswordBox x:Name="PasswordB" Margin="0,0,0,8" />
                    </StackPanel>
                    </StackPanel>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>
