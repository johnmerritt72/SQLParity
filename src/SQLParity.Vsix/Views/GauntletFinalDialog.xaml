<Window x:Class="SQLParity.Vsix.Views.GauntletFinalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Last Chance"
        SizeToContent="WidthAndHeight"
        MinWidth="400" MinHeight="250"
        MaxWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
        Loaded="Window_Loaded">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Destination -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Destination: " FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
            <TextBlock Text="{Binding DestinationLabel}" FontSize="18" FontWeight="Bold"
                       Foreground="{Binding DestinationColor}" />
            <TextBlock Text="{Binding DestinationTag, StringFormat=' ({0})'}" FontSize="14"
                       VerticalAlignment="Bottom" Margin="4,0,0,2"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
        </StackPanel>

        <!-- Change count -->
        <TextBlock Grid.Row="1" Margin="0,0,0,8"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
            <Run Text="About to apply" />
            <Run Text="{Binding TotalSelectedCount, Mode=OneWay}" FontWeight="Bold" />
            <Run Text="change(s), including" />
            <Run Text="{Binding DestructiveCount, Mode=OneWay}" FontWeight="Bold" Foreground="Red" />
            <Run Text="destructive." />
        </TextBlock>

        <!-- Warning -->
        <TextBlock Grid.Row="2" Text="This action cannot be undone." FontWeight="Bold"
                   Foreground="Red" Margin="0,0,0,16" />

        <!-- Countdown -->
        <TextBlock Grid.Row="3" Margin="0,0,0,12"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="Ready to proceed." />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CanProceedFinal}" Value="False">
                            <Setter Property="Text" Value="{Binding CountdownSeconds, StringFormat='Confirm button enables in {0}...'}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Proceed" IsDefault="True" Padding="16,6" Margin="0,0,8,0"
                    IsEnabled="{Binding CanProceedFinal}" Click="Proceed_Click" />
            <Button Content="Cancel" IsCancel="True" Padding="16,6" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
