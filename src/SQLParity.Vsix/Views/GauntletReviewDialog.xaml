<Window x:Class="SQLParity.Vsix.Views.GauntletReviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Destructive Changes -- Review Required"
        SizeToContent="WidthAndHeight"
        MinWidth="500" MinHeight="400"
        MaxWidth="800" MaxHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Destination label -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="Destination: " FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
            <TextBlock Text="{Binding DestinationLabel}" FontSize="18" FontWeight="Bold"
                       Foreground="{Binding DestinationColor}" />
        </StackPanel>

        <!-- Warning text -->
        <TextBlock Grid.Row="1" TextWrapping="Wrap" Margin="0,0,0,8"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
            <Run Text="The following" />
            <Run Text="{Binding DestructiveCount, Mode=OneWay}" FontWeight="Bold" />
            <Run Text="destructive change(s) will be applied. Review carefully:" />
        </TextBlock>

        <!-- Destructive changes list -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,12" Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding DestructiveChanges}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <TextBlock Text="{Binding Id}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                                <ItemsControl ItemsSource="{Binding Reasons}" Margin="16,2,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" Foreground="Red" FontSize="11" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Type to confirm -->
        <TextBlock Grid.Row="3" Margin="0,0,0,4"
                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}">
            <Run Text="Type" />
            <Run Text="{Binding DestinationLabel, Mode=OneWay}" FontWeight="Bold" />
            <Run Text="to confirm:" />
        </TextBlock>

        <TextBox Grid.Row="4" Text="{Binding TypedLabel, UpdateSourceTrigger=PropertyChanged}"
                 Margin="0,0,0,12" Padding="4" />

        <!-- Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Confirm" IsDefault="True" Padding="16,6" Margin="0,0,8,0"
                    IsEnabled="{Binding LabelMatches}" Click="Confirm_Click" />
            <Button Content="Cancel" IsCancel="True" Padding="16,6" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>
