<UserControl x:Class="SQLParity.Vsix.Views.ResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SQLParity.Vsix.ViewModels"
             xmlns:views="clr-namespace:SQLParity.Vsix.Views"
             Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Row 0: Identity Bar -->
        <Border Grid.Row="0" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Direction controls (centered) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- When direction is Unset: show two buttons -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Direction.Direction}" Value="Unset">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Button Command="{Binding Direction.SetAtoBCommand}" Padding="8,4" Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Direction.LabelA}" />
                                <TextBlock Text=" &#x2192; " />
                                <TextBlock Text="{Binding Direction.LabelB}" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding Direction.SetBtoACommand}" Padding="8,4" Margin="4,0"
                                ToolTip="{Binding Direction.BtoAToolTip}"
                                ToolTipService.ShowOnDisabled="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Direction.LabelB}" />
                                <TextBlock Text=" &#x2192; " />
                                <TextBlock Text="{Binding Direction.LabelA}" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <!-- When direction is Set: show arrow text + Flip -->
                    <StackPanel Orientation="Horizontal">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Direction.Direction}" Value="Unset">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="{Binding Direction.ArrowText}" VerticalAlignment="Center" FontWeight="SemiBold"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" Margin="0,0,8,0" />
                        <Button Content="Flip" Command="{Binding Direction.FlipCommand}" Padding="8,4"
                                ToolTip="{Binding Direction.BtoAToolTip}"
                                ToolTipService.ShowOnDisabled="True" />
                    </StackPanel>
                </StackPanel>

                <!-- Toast message for direction flips -->
                <TextBlock Grid.Row="1"
                           Text="{Binding ToastMessage}"
                           Foreground="Orange" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToastMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Row 1: Tree + Detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="150" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Left: Change Tree -->
            <DockPanel Grid.Column="0">
                <TextBlock DockPanel.Dock="Bottom" Text="{Binding SummaryText}" Margin="4"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                           TextWrapping="Wrap" FontSize="11" />

                <!-- Top toolbar: filter + bulk check actions -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Filter tree by object name" />
                        <Button Grid.Column="1" Content="Clear" Margin="4,0,0,0" Padding="8,2"
                                Command="{Binding ClearFilterCommand}" />
                    </Grid>
                    <WrapPanel>
                        <Button Content="Check All" Margin="0,0,4,2" Padding="6,2"
                                Command="{Binding CheckAllCommand}" />
                        <Button Content="Uncheck All" Margin="0,0,4,2" Padding="6,2"
                                Command="{Binding UncheckAllCommand}" />
                        <Button Content="Uncheck Destructive" Margin="0,0,4,2" Padding="6,2"
                                Foreground="#C62828"
                                Command="{Binding UncheckDestructiveCommand}" />
                        <Button Content="Uncheck Risky" Margin="0,0,4,2" Padding="6,2"
                                Foreground="#E65100"
                                Command="{Binding UncheckRiskyCommand}" />
                        <Button Content="Check Only Safe" Margin="0,0,4,2" Padding="6,2"
                                Foreground="#2E7D32"
                                Command="{Binding CheckOnlySafeCommand}" />
                        <Button Content="Uncheck External Refs" Margin="0,0,4,2" Padding="6,2"
                                Foreground="#E65100"
                                ToolTip="Uncheck objects that reference external databases or linked servers — they typically can't be synced to a blank target"
                                Command="{Binding UncheckExternalRefsCommand}" />
                    </WrapPanel>
                </StackPanel>

                <TreeView x:Name="ChangeTree" ItemsSource="{Binding TreeItems}"
                          SelectedItemChanged="ChangeTree_SelectedItemChanged"
                          BorderThickness="0"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type vm:ChangeTreeItemViewModel}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <CheckBox IsChecked="{Binding IsChecked}" Margin="0,0,4,0">
                                    <CheckBox.Style>
                                        <Style TargetType="CheckBox">
                                            <Setter Property="IsThreeState" Value="False" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                    <Setter Property="IsThreeState" Value="True" />
                                                    <Setter Property="FontWeight" Value="Bold" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </CheckBox.Style>
                                </CheckBox>
                                <TextBlock Text="{Binding StatusIcon}" Margin="0,0,1,0" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="ADD">
                                                    <Setter Property="Foreground" Value="#0066CC" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="DROP">
                                                    <Setter Property="Foreground" Value="Red" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="MODIFY">
                                                    <Setter Property="Foreground" Value="#7B2D8E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding StatusLabel}" Margin="0,0,4,0" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="ADD">
                                                    <Setter Property="Foreground" Value="#0066CC" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="DROP">
                                                    <Setter Property="Foreground" Value="Red" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusLabel}" Value="MODIFY">
                                                    <Setter Property="Foreground" Value="#7B2D8E" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding RiskIcon}" Margin="0,0,4,0" FontSize="9"
                                           FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Foreground" Value="Gray" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RiskIcon}" Value="SAFE">
                                                    <Setter Property="Foreground" Value="#2E7D32" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RiskIcon}" Value="CAUTION">
                                                    <Setter Property="Foreground" Value="#F9A825" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RiskIcon}" Value="RISKY">
                                                    <Setter Property="Foreground" Value="#E65100" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding RiskIcon}" Value="DESTRUCTIVE">
                                                    <Setter Property="Foreground" Value="#C62828" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                                <!-- External reference warning icon -->
                                <TextBlock Text="⚠ external refs"
                                           Margin="6,0,0,0" FontSize="10" FontWeight="Bold"
                                           Foreground="#E65100"
                                           ToolTip="{Binding ExternalReferencesTooltip}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasExternalReferences}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />

            <!-- Right: Detail Panel -->
            <Grid Grid.Column="2" Margin="8">
                <!-- Detail content (shown when an item is selected) -->
                <Grid x:Name="DetailContent" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" MinHeight="60" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="2*" MinHeight="100" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: Object name header -->
                    <TextBlock Grid.Row="0" Text="{Binding SelectedObjectName}" FontWeight="Bold" FontSize="14"
                               Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" Margin="0,0,0,4" />

                    <!-- Row 1: Risk text + WinMerge button -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="{Binding SelectedRiskText}" VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        <Button Content="Open in WinMerge" Padding="8,2" Margin="12,0,0,0"
                                Click="OpenInWinMerge_Click" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Row 2: Table detail tree (shown only for table changes) -->
                    <views:TableDetailView Grid.Row="2" DataContext="{Binding TableTreeItems}"
                                           Margin="0,0,0,0">
                        <views:TableDetailView.Style>
                            <Style TargetType="views:TableDetailView">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.IsTableSelected, RelativeSource={RelativeSource AncestorType=views:ResultsView}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </views:TableDetailView.Style>
                    </views:TableDetailView>

                    <!-- Row 3: GridSplitter between table tree and DDL -->
                    <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}" />

                    <!-- Row 4: DDL panels -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="DdlHeaderA" Grid.Row="0" Grid.Column="0" Text="{Binding CurrentSideALabel, StringFormat='Side A: {0}'}"
                                   FontWeight="SemiBold" Margin="0,0,4,4"
                                   Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,4">
                            <TextBlock x:Name="DdlHeaderB"
                                       Text="{Binding Direction.LabelBWithDb, StringFormat='Side B: {0}'}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                            <TextBlock Text="{Binding SelectedSideBFileName, StringFormat='   →   {0}'}"
                                       FontStyle="Italic"
                                       Foreground="Gray"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedSideBFileName}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>

                        <Border x:Name="DdlBorderA" Grid.Row="1" Grid.Column="0"
                                BorderThickness="2" CornerRadius="2" Margin="0,0,4,0"
                                BorderBrush="Gray">
                            <RichTextBox x:Name="DdlBoxA"
                                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" BorderThickness="0" />
                        </Border>
                        <Border x:Name="DdlBorderB" Grid.Row="1" Grid.Column="1"
                                BorderThickness="2" CornerRadius="2" Margin="4,0,0,0"
                                BorderBrush="Gray">
                            <RichTextBox x:Name="DdlBoxB"
                                         IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                         HorizontalScrollBarVisibility="Auto" BorderThickness="0" />
                        </Border>

                        <!-- Loading overlay for DDL panels -->
                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Opacity="0.8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoadingDdl}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Loading DDL..." FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
                        </Border>
                    </Grid>
                </Grid>

                <!-- Placeholder when nothing selected -->
                <TextBlock x:Name="NoSelectionPlaceholder"
                           Text="Select an item from the tree to view details."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" />
            </Grid>
        </Grid>

        <!-- Row 2: Action Bar -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="0,1,0,0" Padding="8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="Generate Script" FontWeight="Bold" Padding="12,6" Margin="4,0"
                            Command="{Binding DataContext.GenerateScriptCommand,
                                RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}" />
                    <Button Content="Apply Live" Padding="12,6" Margin="4,0"
                            Command="{Binding DataContext.ApplyLiveCommand,
                                RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}" />
                </StackPanel>
                <Button DockPanel.Dock="Left" Content="Start Over" Padding="12,6" Margin="0,0,8,0"
                        Command="{Binding DataContext.StartOverCommand,
                            RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}" />

                <!-- Status text -->
                <TextBlock VerticalAlignment="Center" Margin="4,0"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Direction.Direction}" Value="Unset">
                                    <Setter Property="Text" Value="Select sync direction first" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Direction.IsDestinationProd}" Value="True">
                                    <Setter Property="Text" Value="PROD -- live apply disabled" />
                                    <Setter Property="Foreground" Value="Red" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- Busy overlay for Generate Script / Apply Live -->
        <Border Grid.RowSpan="3"
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}" Opacity="0.9">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsBusy,
                            RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="{Binding DataContext.ProgressText,
                               RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}"
                           FontSize="14" HorizontalAlignment="Center"
                           Foreground="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}" />
                <ProgressBar Width="400" Height="20" Margin="0,12,0,0"
                             Value="{Binding DataContext.ProgressValue,
                                 RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}"
                             Maximum="{Binding DataContext.ProgressMaximum,
                                 RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="IsIndeterminate" Value="False" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.ProgressMaximum,
                                    RelativeSource={RelativeSource AncestorType=views:ComparisonHostView}}" Value="0">
                                    <Setter Property="IsIndeterminate" Value="True" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
